{
  "name": "@shuffleio/shuffle-core",
  "version": "0.0.0-VERSION",
  "description": "Standalone React surfaces from the Shuffle Security app — Usecases explorer, form control, and more.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shuffle/singul.js.git"
  },
  "homepage": "https://github.com/Shuffle/singul.js#readme",
  "keywords": [
    "react",
    "shuffle",
    "usecases",
    "security",
    "soar"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./shuffle-core.css": "./dist/shuffle-core.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@mui/material": ">=5",
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "lucide-react": ">=0.300.0",
    "react-router-dom": ">=6",
    "@shuffleio/shuffle-mcps": ">=0.0.32"
  },
  "dependencies": {
    "algoliasearch": "^5.0.0",
    "@tanstack/react-query": "^5.0.0",
    "react-ga4": "^2.1.0",
    "react-device-detect": "^2.2.0",
    "mui-chips-input": "^2.1.0",
    "react-toastify": "^9.1.3",
    "dayjs": "^1.11.0",
    "tailwind-merge": "^2.0.0",
    "clsx": "^2.0.0",
    "recharts": "^2.15.0",
    "date-fns": "^3.0.0",
    "framer-motion": "^11.0.0",
    "react-markdown": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@mui/material": "^5.15.0",
    
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "react-ga4": "^2.1.0",
    "lucide-react": "^0.300.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
