{
  "name": "@shuffleio/shuffle-core",
  "version": "0.0.1-test",
  "description": "Standalone React surfaces from the Shuffle Security app — Usecases explorer, form control, and more.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shuffle/singul.js.git"
  },
  "homepage": "https://github.com/Shuffle/singul.js#readme",
  "keywords": [
    "react",
    "shuffle",
    "usecases",
    "security",
    "soar"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./shuffle-core.css": "./dist/shuffle-core.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@mui/material": ">=5",
    "@mui/icons-material": ">=5",
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "lucide-react": ">=0.300.0",
    "react-router-dom": ">=6",
    "react-ga4": ">=2",
    "@shuffleio/shuffle-mcps": ">=0.1.0"
  },
  "dependencies": {
    "algoliasearch": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}