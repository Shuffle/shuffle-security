{
  "name": "@shuffleio/shuffle-mcps",
  "version": "0.0.0-VERSION",
  "description": "Turn 3,000+ SaaS tools into MCP servers your agents can use. Headless React component for search, selection, and OAuth handoff.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shuffle/singul.js.git"
  },
  "homepage": "https://github.com/Shuffle/singul.js#readme",
  "keywords": [
    "react",
    "integrations",
    "oauth",
    "mcp",
    "algolia",
    "search",
    "shuffle",
    "singul"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./shuffle-mcp.css": "./dist/shuffle-mcp.css"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@mui/material": ">=5",
    "@mui/icons-material": ">=5",
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "framer-motion": ">=10",
    "sonner": ">=1",
    "lucide-react": ">=0.300.0",
    "react-router-dom": ">=6",
    "react-markdown": ">=8",
    "remark-gfm": ">=3"
  },
  "peerDependenciesMeta": {
    "react-router-dom": { "optional": true }
  },
  "dependencies": {
    "algoliasearch": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
