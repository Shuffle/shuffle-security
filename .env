# Shuffle Security — default environment.
# This file is committed so `docker compose up -d` works out of the box.
# Override anything here for production deployments.

# ---- Ports ----
SHUFFLE_SECURITY_PORT=3002
SHUFFLE_SECURITY_PORT_HTTPS=3444
FRONTEND_PORT=3001
FRONTEND_PORT_HTTPS=3443
BACKEND_PORT=5001

# ---- Hostnames ----
BACKEND_HOSTNAME=shuffle-backend
OUTER_HOSTNAME=shuffle-backend

# ---- Local storage paths (created automatically on first run) ----
DB_LOCATION=./shuffle-database
SHUFFLE_FILE_LOCATION=./shuffle-files
SHUFFLE_APP_HOTLOAD_LOCATION=./shuffle-apps

# ---- OpenSearch ----
SHUFFLE_OPENSEARCH_PASSWORD=StrongShufflePassword321!

# ---- Proxies (leave empty unless behind a corporate proxy) ----
HTTP_PROXY=
HTTPS_PROXY=
SHUFFLE_PASS_WORKER_PROXY=TRUE
SHUFFLE_PASS_APP_PROXY=TRUE

# ---- Backend internals (used by orborus/backend) ----
ENVIRONMENT_NAME=Shuffle
SHUFFLE_APP_HOTLOAD_FOLDER=/shuffle-apps
DOCKER_API_VERSION=1.40
